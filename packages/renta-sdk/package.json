{
  "name": "@renta/sdk",
  "version": "0.2.0",
  "description": "Official TypeScript SDK for the Renta API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/renta-labs/renta-sdk.git"
  },
  "homepage": "https://github.com/renta-labs/renta-sdk#readme",
  "bugs": {
    "url": "https://github.com/renta-labs/renta-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./storefront": {
      "import": {
        "types": "./dist/storefront.d.ts",
        "default": "./dist/storefront.js"
      },
      "require": {
        "types": "./dist/storefront.d.cts",
        "default": "./dist/storefront.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "keywords": [
    "renta",
    "rental",
    "booking",
    "sdk",
    "api",
    "typescript"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
